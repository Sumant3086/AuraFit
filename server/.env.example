# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# Free tier: MongoDB Atlas (512MB free) — cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<db_password>@<cluster>.mongodb.net/<dbname>

# ── Security (REQUIRED) ──────────────────────────────────────
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<your_jwt_secret_min_32_chars>
JWT_REFRESH_SECRET=<your_refresh_secret_different_from_jwt>

# ── AI Services ──────────────────────────────────────────────
# Free tier: Google Gemini API — ai.google.dev
GOOGLE_API_KEY=<your_google_gemini_api_key>

# ── Email (Gmail SMTP) ───────────────────────────────────────
# 1. Enable 2FA on your Gmail account
# 2. Generate an App Password at myaccount.google.com/apppasswords
EMAIL_USER=<your_gmail_address>
EMAIL_APP_PASSWORD=<your_16_char_gmail_app_password>

# ── Payment (Razorpay) ───────────────────────────────────────
# Free account at dashboard.razorpay.com
# Use rzp_test_ keys for development, rzp_live_ for production
RAZORPAY_KEY_ID=<your_razorpay_key_id>
RAZORPAY_KEY_SECRET=<your_razorpay_key_secret>
RAZORPAY_WEBHOOK_SECRET=<your_razorpay_webhook_secret>

# ── Media Upload (Cloudinary — Free Tier) ────────────────────
# Free at cloudinary.com — create unsigned upload preset "aurafit_unsigned"
CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_UPLOAD_PRESET=aurafit_unsigned

# ── Cache (Redis — Optional) ─────────────────────────────────
# Free tier: upstash.com
REDIS_URL=redis://<username>:<token>@<host>:<port>

# ── Seed / Demo ──────────────────────────────────────────────
# Password assigned to demo users when running POST /api/seed
SEED_DEMO_PASSWORD=<choose_a_demo_password>

# ── Admin Account ─────────────────────────────────────────────
# Email/password for the admin user in MongoDB
ADMIN_EMAIL=<admin_email>
ADMIN_NAME=<admin_display_name>
# Note: Set a strong admin password directly in MongoDB Atlas
# or via the signup endpoint. Do not store it here in production.
