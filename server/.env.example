# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# Free tier: MongoDB Atlas (512MB free)
# Get connection string from: cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aurafit?retryWrites=true&w=majority

# ── Security (REQUIRED — generate 64-char random strings) ────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_64_char_random_string_here
JWT_REFRESH_SECRET=generate_another_64_char_random_string_here

# ── AI Services ──────────────────────────────────────────────
# Free tier: Google Gemini API (at ai.google.dev)
GOOGLE_API_KEY=your_google_gemini_api_key

# ── Email (Free via Gmail SMTP) ──────────────────────────────
# 1. Enable 2FA on your Gmail account
# 2. Generate an App Password at myaccount.google.com/apppasswords
# 3. Use the 16-character generated password (not your Gmail password)
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Payment (Razorpay) ───────────────────────────────────────
# Free account at dashboard.razorpay.com
# Use rzp_test_ keys for development, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret: Set in Razorpay Dashboard → Webhooks → Add Webhook → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_signing_secret

# ── Media Upload (Cloudinary — Free Tier: 25GB) ──────────────
# Create free account at cloudinary.com
# Find in Dashboard → Settings → Upload → Upload presets (create "unsigned" preset)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=aurafit_unsigned

# ── Cache (Redis — Optional but recommended for performance) ──
# Free tier: Upstash Redis (10K commands/day free)
# Get URL from: upstash.com → Create Database → REST API URL
REDIS_URL=redis://default:password@your-redis-host.upstash.io:6379

# ── Admin Credentials ─────────────────────────────────────────
ADMIN_EMAIL=admin@yourgym.com
ADMIN_PASSWORD=YourStrongAdminPassword123!
ADMIN_NAME=Gym Admin

# ── Frontend (Vite) ───────────────────────────────────────────
# Add these to your root .env file (not server/.env):
# VITE_API_URL=/api
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=aurafit_unsigned
# VITE_RAZORPAY_KEY=rzp_test_your_key_id
