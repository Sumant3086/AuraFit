# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# Get your connection string from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://[user]:[pass]@[cluster].mongodb.net/[dbname]
MONGODB_URI=

# ── Security ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── AI ────────────────────────────────────────────────────────
# Free at ai.google.dev
GOOGLE_API_KEY=

# ── Email (optional) ──────────────────────────────────────────
EMAIL_USER=
EMAIL_APP_PASSWORD=

# ── Payment ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=aurafit_unsigned

# ── Cache (optional) ──────────────────────────────────────────
REDIS_URL=

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_NAME=

# ── Seed (optional) ───────────────────────────────────────────
SEED_DEMO_PASSWORD=
