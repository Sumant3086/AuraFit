# ── Frontend Configuration (Vite uses VITE_ prefix) ───────────
# These go in your root .env file (NOT server/.env)

# API URL
# Development: http://localhost:5000/api
# Production: /api (relative, served from same origin)
VITE_API_URL=/api

# ── Payment ────────────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=<your_razorpay_key_id>

# ── Media Upload (Cloudinary) ─────────────────────────────────
# Sign up free at cloudinary.com
# Create an unsigned upload preset named "aurafit_unsigned"
VITE_CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>
VITE_CLOUDINARY_UPLOAD_PRESET=aurafit_unsigned

# ── Display ────────────────────────────────────────────────────
VITE_ADMIN_NAME=<admin_display_name>

# ── See server/.env.example for backend variables ─────────────
