# ── Frontend Configuration (Vite uses VITE_ prefix) ───────────
# These go in your root .env file (NOT server/.env)

# API URL
# Development: http://localhost:5000/api
# Production: /api (served from same origin via proxy)
VITE_API_URL=/api

# ── Payment ────────────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ── Media Upload (Cloudinary — free at cloudinary.com) ────────
# Sign up free → Settings → Upload → Create unsigned upload preset named 'aurafit_unsigned'
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=aurafit_unsigned

# ── Admin (legacy, for direct admin UI access) ────────────────
VITE_ADMIN_EMAIL=admin@yourgym.com
VITE_ADMIN_PASSWORD=your_admin_password
VITE_ADMIN_NAME=Gym Admin

# ── Social Media Links ─────────────────────────────────────────
VITE_INSTAGRAM_URL=https://www.instagram.com/aurafit
VITE_YOUTUBE_URL=https://www.youtube.com/@aurafit
VITE_FACEBOOK_URL=https://www.facebook.com/aurafit

# ── See server/.env.example for backend variables ─────────────
