{
  "name": "aurafit",
  "version": "1.0.0",
  "description": "AI-powered fitness platform — personalized workouts, nutrition, QR check-ins, and gamified progress.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@google/generative-ai": "^0.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "aos": "^2.3.4",
    "axios": "^1.6.2",
    "chart.js": "^4.5.1",
    "classnames": "^2.3.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^10.16.16",
    "html5-qrcode": "^2.3.8",
    "react": "^18.2.0",
    "react-awesome-reveal": "^4.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^4.12.0",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^6.27.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "styled-components": "^6.1.1",
    "swiper": "^12.1.3",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "workbox-window": "^7.4.1"
  },
  "scripts": {
    "predev": "node scripts/killPort.cjs",
    "dev": "concurrently \"vite\" \"cd server && npm run dev\" --names \"CLIENT,SERVER\" --prefix-colors \"cyan,green\"",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "kill": "node scripts/killPort.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "render-build": "npm ci && npm run build && cd server && npm ci",
    "render-start": "cd server && node server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["fitness", "gym", "ai", "workout", "nutrition", "react", "nodejs", "mongodb"],
  "author": "Sumant Yadav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sumant3086/AuraFit.git"
  }
}
